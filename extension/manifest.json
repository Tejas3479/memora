{
  "manifest_version": 3,
  "name": "Memora - Personal Memory Layer",
  "version": "2.0.0",
  "description": "Capture, index, and recall everything you read, write, and discuss.",
  "permissions": ["activeTab", "storage", "contextMenus", "alarms", "sidePanel"],
  "host_permissions": ["https://*/*", "http://*/*"],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
