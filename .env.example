# ============================================================================
# MEMORA — Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# ============================================================================

# ----------------------------------------------------------------------------
# SERVER
# ----------------------------------------------------------------------------

# PostgreSQL connection string
DATABASE_URL="postgresql://memora:memora@localhost:5432/memora?schema=public"

# Redis connection string
REDIS_URL="redis://localhost:6379"

# Qdrant vector database URL
QDRANT_URL="http://localhost:6333"

# Voyage AI API key (embedding model)
VOYAGE_API_KEY=""

# Google AI API key (Gemini LLM)
GOOGLE_API_KEY=""

# JWT key pair for authentication (RS256)
# Generate with: openssl genpkey -algorithm RSA -out private.pem -pkeyopt rsa_keygen_bits:2048
# Then: openssl rsa -pubout -in private.pem -out public.pem
JWT_PRIVATE_KEY=""
JWT_PUBLIC_KEY=""

# AES-256 key for encrypting stored tokens (hex-encoded, 64 chars)
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=""

# Stripe billing
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Zep long-term memory
ZEP_API_URL="http://localhost:8000"
ZEP_API_KEY=""

# LangSmith observability (optional)
LANGSMITH_API_KEY=""
LANGSMITH_PROJECT="memora"

# ----------------------------------------------------------------------------
# CLIENT (Vite)
# ----------------------------------------------------------------------------

# API base URL for the client app
VITE_API_URL="http://localhost:3000/api"

# WebSocket URL for real-time updates
VITE_WS_URL="ws://localhost:3000/ws"

# ----------------------------------------------------------------------------
# EXTENSION (Browser)
# ----------------------------------------------------------------------------

# Memora API URL for the browser extension
MEMORA_API_URL="http://localhost:3000/api"

# ----------------------------------------------------------------------------
# WORKER
# ----------------------------------------------------------------------------

# Workers share the same infra as the server
# DATABASE_URL  — same as SERVER
# REDIS_URL     — same as SERVER
# QDRANT_URL    — same as SERVER

# ----------------------------------------------------------------------------
# INTEGRATIONS — OAuth Credentials
# ----------------------------------------------------------------------------

# Slack
SLACK_CLIENT_ID=""
SLACK_CLIENT_SECRET=""

# Notion
NOTION_CLIENT_ID=""
NOTION_CLIENT_SECRET=""

# Google (Calendar, Drive, etc.)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
